{% extends "base.njk" %}

{% block title %}{{ product.título }} - Tienda Prado{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-5">
  <ol class="breadcrumb" style="font-size: 0.8rem;">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">IMPRESIONES</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ product.título }}</li>
  </ol>
</nav>

<div class="row align-items-center">
    <div class="col-md-6 mb-4 mb-md-0">
        <div class="bg-light p-4 text-center">
            <img src="/public/imagenes/{{ product.imagen }}" class="img-fluid object-fit-contain" style="max-height: 500px;" alt="{{ product.título }}">
        </div>
    </div>
    <div class="col-md-5 offset-md-1">
        <h1 class="display-5 mb-3">{{ product.título }}</h1>
        <div class="mb-4 text-muted">
            {{ product.descripción | safe | nl2br }}
        </div>
        <h3 class="mb-4 fw-bold">{{ product.precio }} €</h3>
        
        <form action="/al-carrito/{{ product.id }}" method="POST" class="d-flex align-items-center mb-4">
            <input type="number" name="cantidad" class="form-control me-3" value="1" min="1" style="width: 70px; border-radius: 0;">
            <button type="submit" class="btn btn-prado flex-grow-1">Añadir a la cesta</button>
        </form>
        
        <div class="d-flex gap-3 text-muted" style="font-size: 0.9rem;">
            <span><i class="bi bi-heart"></i> Guardar</span>
            <span><i class="bi bi-share"></i> Compartir</span>
        </div>
    </div>
</div>
{% endblock %}
