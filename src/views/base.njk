<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tienda Prado{% endblock %}</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --prado-dark: #2c2c2c;
            --prado-light: #f9f9f9;
            --prado-accent: #7a7a7a;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--prado-dark);
        }
        h1, h2, h3, .navbar-brand {
            font-family: 'Playfair Display', serif;
            letter-spacing: 1px;
        }
        .navbar {
            border-bottom: 1px solid #eee;
            background-color: #fff !important;
            padding: 1.5rem 0;
        }
        .navbar-brand {
            font-size: 1.8rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .search-form .form-control {
            border-radius: 20px;
            padding-left: 1.5rem;
            border: 1px solid #ddd;
            font-size: 0.9rem;
        }
        .footer {
            border-top: 1px solid #eee;
            padding: 3rem 0;
            margin-top: 5rem;
            font-size: 0.8rem;
            color: var(--prado-accent);
        }
        .btn-prado {
            background-color: var(--prado-dark);
            color: #fff;
            border-radius: 0;
            padding: 0.8rem 2rem;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
            transition: all 0.3s;
        }
        .btn-prado:hover {
            background-color: #000;
            color: #fff;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand mx-auto d-block d-lg-none" href="/">TIENDA PRADO</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 d-none d-lg-flex">
                   <li class="nav-item"><a class="nav-link" href="/">IMPRESIONES</a></li>
                </ul>
                <a class="navbar-brand mx-auto d-none d-lg-block" href="/">TIENDA PRADO</a>
                <form class="d-flex search-form" action="/buscar" method="GET">
                    <input class="form-control me-2" type="search" name="busqueda" placeholder="Buscar..." aria-label="Search" value="{{ query }}">
                </form>
            </div>
        </div>
    </nav>

    <main class="container mt-5">
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container text-center">
            <p>&copy; 2024 TIENDA PRADO - Misión Académica SSBW</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
